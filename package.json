{
  "name": "edge-native-db",
  "version": "0.1.0",
  "description": "Offline-first sync engine for edge devices — HLC ordering, CRDT merge, SQLite WAL, zero config",
  "keywords": [
    "offline-first", "sync", "edge", "crdt", "hlc", "sqlite",
    "iot", "field-systems", "conflict-resolution", "local-first",
    "eventually-consistent", "typescript"
  ],
  "author": "Edge Native DB contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/edge-native-db"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "main":  "./dist/sdk/index.js",
  "types": "./dist/sdk/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/sdk/index.d.ts",
      "default": "./dist/sdk/index.js"
    },
    "./server": {
      "types":   "./dist/server/sync-server.d.ts",
      "default": "./dist/server/sync-server.js"
    },
    "./simulator": {
      "types":   "./dist/simulator/multi-device.d.ts",
      "default": "./dist/simulator/multi-device.js"
    }
  },
  "files": [
    "dist/",
    "LICENSE"
  ],
  "scripts": {
    "dev":         "ts-node src/index.ts",
    "build":       "tsc -p tsconfig.build.json",
    "start":       "node dist/index.js",
    "test":        "jest --forceExit",
    "test:watch":  "jest --watch",
    "typecheck":   "tsc --noEmit",
    "prepublish":  "npm run build"
  },
  "dependencies": {
    "express": "^4.19.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest":    "^30.0.0",
    "@types/node":    "^22.15.0",
    "@types/uuid":    "^9.0.8",
    "jest":           "^29.7.0",
    "ts-jest":        "^29.1.5",
    "ts-node":        "^10.9.2",
    "typescript":     "^5.5.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "testTimeout": 15000,
    "maxWorkers": 4,
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "tsconfig": "tsconfig.test.json" }]
    }
  }
}
